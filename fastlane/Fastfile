# Reusable iOS → App Store Connect Fastfile template.
#
# Fill in the three placeholders below, drop this at <project>/fastlane/Fastfile.
# Auth: set ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_FILEPATH (env or fastlane/.env).
#
# LOCAL lanes (need full Xcode):
#   fastlane build_and_upload    # cert + sigh + gym + pilot (no review submission)
#   fastlane upload_all          # metadata + screenshots (no build, no submit)
#   fastlane submit_version      # attach build + metadata to a version, SUBMIT for review
#   fastlane cancel_and_submit   # cancel a stuck in-progress submission, then submit
#   fastlane asc_status          # print version states + recent build processing states
#
# CI lanes (run on GitHub Actions macOS runner — see references/workflows/):
#   fastlane ci_build_and_upload   # manual-signed build + upload (no submit)
#   fastlane ci_release_and_submit # build → WAIT for processing → submit (full auto)

# ---- per-project config ----
APP_IDENTIFIER = "com.bochen.bike"      # <-- your Bundle ID
SCHEME         = "Bike"                 # <-- your scheme
PROJECT        = "Bike.xcodeproj"       # <-- or use `workspace:` in gym instead

# watchOS companion app + widget extension ship inside the same .ipa and each need their
# own App Store distribution profile (they declare App Groups / HealthKit entitlements that
# `-allowProvisioningUpdates` can't satisfy headlessly during `-exportArchive`).
EXTRA_BUNDLE_IDS = [
  "com.bochen.bike.watchkitapp",
  "com.bochen.bike.watchkitapp.widget"
]

default_platform(:ios)

# ----- shared: API Key loader -----
def asc_api_key
  app_store_connect_api_key(
    key_id:       ENV.fetch("ASC_KEY_ID")       { abort("missing ASC_KEY_ID env var") },
    issuer_id:    ENV.fetch("ASC_ISSUER_ID")    { abort("missing ASC_ISSUER_ID env var") },
    key_filepath: ENV.fetch("ASC_KEY_FILEPATH") { abort("missing ASC_KEY_FILEPATH env var") },
    duration:     1200,
    in_house:     false
  )
end

platform :ios do

  # 只归档导出 .ipa，不上传。用于上传前 altool --validate-app 预检。
  desc "Archive + export .ipa only (no upload) for pre-validation"
  lane :build_only do
    cert(api_key: asc_api_key, development: false, output_path: "./fastlane/certs")
    profiles = {}
    ([APP_IDENTIFIER] + EXTRA_BUNDLE_IDS).each do |bundle_id|
      sigh(api_key: asc_api_key, app_identifier: bundle_id, output_path: "./fastlane/profiles")
      profiles[bundle_id] = lane_context[SharedValues::SIGH_NAME]
    end
    gym(
      scheme: SCHEME, project: PROJECT, export_method: "app-store",
      output_directory: "./build", output_name: "#{SCHEME}.ipa", clean: true,
      export_options: { method: "app-store", signingStyle: "manual", provisioningProfiles: profiles }
    )
  end

  # 把版本记录设为 1.1 并挂上 1.1(1) 这个 build，观察 INVALID_BINARY 是否消除。
  # 只改版本+选 build，不提交审核。用来验证「二进制到底行不行」。
  desc "Select build 1.1(1) for the App Store version and report the resulting state"
  lane :use_build do
    api_key = asc_api_key
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from(hash: api_key)
    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    rc = Spaceship::ConnectAPI.client.tunes_request_client

    # 找 train=1.1 的 build
    resp = rc.get("v1/builds?filter[app]=#{app.id}&include=preReleaseVersion&limit=50&sort=-uploadedDate").body
    prv = {}
    (resp["included"] || []).each { |i| prv[i["id"]] = i.dig("attributes", "version") if i["type"] == "preReleaseVersions" }
    b = (resp["data"] || []).find { |bd| prv[bd.dig("relationships", "preReleaseVersion", "data", "id")] == "1.1" }
    UI.user_error!("没找到 train=1.1 的 build") unless b
    UI.important("build 1.1(#{b.dig('attributes','version')}) id=#{b['id']} processing=#{b.dig('attributes','processingState')}")

    # 可编辑版本
    vers = rc.get("v1/apps/#{app.id}/appStoreVersions?limit=10").body["data"] || []
    ver = vers.find { |v| %w[PREPARE_FOR_SUBMISSION INVALID_BINARY DEVELOPER_REJECTED METADATA_REJECTED REJECTED].include?(v.dig("attributes", "appStoreState")) }
    UI.user_error!("没有可编辑版本") unless ver
    UI.message("可编辑版本 #{ver.dig('attributes','versionString')} 现状态=#{ver.dig('attributes','appStoreState')}")

    if ver.dig("attributes", "versionString") != "1.1"
      rc.patch("v1/appStoreVersions/#{ver['id']}", { data: { type: "appStoreVersions", id: ver["id"], attributes: { versionString: "1.1" } } })
      UI.message("版本号已改为 1.1")
    end
    rc.patch("v1/appStoreVersions/#{ver['id']}/relationships/build", { data: { type: "builds", id: b["id"] } })
    UI.message("已把 build 挂到该版本，等 5 秒重新读状态…")
    sleep(5)
    v2 = rc.get("v1/appStoreVersions/#{ver['id']}").body.dig("data", "attributes")
    UI.success("→ 版本 #{v2['versionString']} 现在状态: #{v2['appStoreState']}")
  end

  desc "Archive + upload build to App Store Connect (no review submission)"
  lane :build_and_upload do
    # 1) Distribution certificate (private key generated locally)
    cert(
      api_key:     asc_api_key,
      development: false,
      output_path: "./fastlane/certs"
    )
    # 2) App Store provisioning profile — one per embedded target (main app + watch app +
    #    widget extension). IMPORTANT: do NOT pass adhoc:/development: — newer fastlane
    #    errors with "conflict between options: 'adhoc' and 'development'". Omitting both
    #    yields the App Store profile, which is what we want.
    profiles = {}
    ([APP_IDENTIFIER] + EXTRA_BUNDLE_IDS).each do |bundle_id|
      sigh(
        api_key:        asc_api_key,
        app_identifier: bundle_id,
        output_path:    "./fastlane/profiles"
      )
      profiles[bundle_id] = lane_context[SharedValues::SIGH_NAME]
    end
    # 3) Archive + export .ipa — manual signing so the watch/widget profiles above are
    #    actually used (automatic + -allowProvisioningUpdates can't fetch per-target
    #    profiles for embedded targets without an Xcode-side Apple ID session).
    gym(
      scheme:           SCHEME,
      project:          PROJECT,
      export_method:    "app-store",
      output_directory: "./build",
      output_name:      "#{SCHEME}.ipa",
      clean:            true,
      export_options:   {
        method:               "app-store",
        signingStyle:         "manual",
        provisioningProfiles: profiles
      }
    )
    # 4) Upload to ASC (TestFlight internal; not external, not submitted for review)
    pilot(
      api_key:                           asc_api_key,
      ipa:                               "./build/#{SCHEME}.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission:                   true,
      distribute_external:               false
    )
  end

  # Diagnostic: print each App Store version's state + the 10 most recent builds'
  # processing states. READ-ONLY — changes nothing. Use it to answer "what's blocking
  # the submit?" (e.g. is a build still PROCESSING, or a version still WAITING_FOR_REVIEW).
  desc "Print current ASC version + build status"
  lane :asc_status do
    api_key = asc_api_key
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from(hash: api_key)
    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    UI.message("App: #{app.name} (#{app.id})")
    app.get_app_store_versions.each do |v|
      UI.message("Version #{v.version_string} — state: #{v.app_store_state}")
    end
    Spaceship::ConnectAPI::Build.all(app_id: app.id, sort: "-uploadedDate", limit: 10, includes: "preReleaseVersion").each do |b|
      UI.message("Build #{b.version} — train: #{b.pre_release_version&.version} — processing: #{b.processing_state} — expired: #{b.expired}")
    end
  end

  # App-level content-rights declaration (required before adding for review).
  # NOTE: App Privacy nutrition labels CANNOT be set via the API-key Connect API —
  # Apple removed the old private dataUsages endpoint. Set them once in the ASC web UI
  # (App 隐私 → 数据未收集 → 发布). Idempotent — safe to re-run.
  desc "Set content rights declaration (no third-party content) via API"
  lane :set_app_privacy_and_rights do
    api_key = asc_api_key
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from(hash: api_key)
    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    rc = Spaceship::ConnectAPI.client.tunes_request_client

    rc.patch("v1/apps/#{app.id}", {
      data: {
        type: "apps",
        id: app.id,
        attributes: { contentRightsDeclaration: "DOES_NOT_USE_THIRD_PARTY_CONTENT" }
      }
    })
    check = rc.get("v1/apps/#{app.id}?fields[apps]=contentRightsDeclaration").body
    UI.success("contentRightsDeclaration = #{check.dig('data', 'attributes', 'contentRightsDeclaration')}")

    # 年龄分级：直接 PATCH ageRatingDeclaration。不走 deliver 的 app_rating —— 新 app 没有
    # review detail 时 deliver 会在到达该步前先崩 "No data"（fetch_app_store_review_detail）。
    app_info = app.fetch_edit_app_info || app.fetch_live_app_info
    UI.user_error!("拿不到可编辑的 app info") unless app_info
    decl = app_info.fetch_age_rating_declaration
    require 'json'
    rating_json = File.exist?("./metadata/app_store_rating_config.json") ? "./metadata/app_store_rating_config.json" : "./fastlane/metadata/app_store_rating_config.json"
    attributes = JSON.parse(File.read(rating_json))
    decl.update(attributes: attributes)
    UI.success("年龄分级问卷已提交（全部无敏感内容）")
  end

  # Create the subscription group, monthly/yearly auto-renewables, 6-locale
  # localizations, CNY-anchored prices equalized to all territories, and worldwide
  # availability — mirroring Bike/StoreKitConfig.storekit. Idempotent.
  desc "Create ASC subscriptions (group + monthly/yearly + localizations + prices)"
  lane :create_subscriptions do
    api_key = asc_api_key
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from(hash: api_key)
    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    rc = Spaceship::ConnectAPI.client.tunes_request_client

    group_ref = "轻骑运动 Pro"
    group_locs = {
      "zh-Hans" => "轻骑运动 Pro",
      "zh-Hant" => "輕騎運動 Pro",
      "en-US"   => "HappyRide Pro",
      "ja"      => "快楽サイクル Pro",
      "ko"      => "해피라이딩 Pro",
      "de-DE"   => "HappyRide Pro"
    }
    subs_spec = [
      {
        product_id: "com.bochen.bike.subscription.monthly",
        ref_name: "Monthly Pro", period: "ONE_MONTH", price_cny: 10.0,
        locs: {
          "zh-Hans" => ["月付订阅", "解锁安静风景路线推荐、逐向导航与高级统计，随时可取消"],
          "zh-Hant" => ["月付訂閱", "解鎖安靜風景路線推薦、逐向導航與進階統計，隨時可取消"],
          "en-US"   => ["Monthly Pro", "Quiet-route nav & stats. Cancel anytime."],
          "ja"      => ["月額プラン", "静か・景色ルート案内と詳細統計。いつでも解約可"],
          "ko"      => ["월간 구독", "조용한/경치 경로 안내와 통계, 언제든 해지 가능"],
          "de-DE"   => ["Monatlich Pro", "Ruhige Routen, Navigation, Statistiken."]
        }
      },
      {
        product_id: "com.bochen.bike.subscription.yearly",
        ref_name: "Yearly Pro", period: "ONE_YEAR", price_cny: 88.0,
        locs: {
          "zh-Hans" => ["年付订阅", "解锁安静风景路线推荐、逐向导航与高级统计"],
          "zh-Hant" => ["年付訂閱", "解鎖安靜風景路線推薦、逐向導航與進階統計"],
          "en-US"   => ["Yearly Pro", "Quiet/scenic route navigation and ride stats."],
          "ja"      => ["年額プラン", "静か・景色ルート案内と詳細統計が使い放題"],
          "ko"      => ["연간 구독", "조용한/경치 경로 안내와 상세 통계 이용"],
          "de-DE"   => ["Jährlich Pro", "Ruhige Routen, Navigation, Statistiken."]
        }
      }
    ]

    # ---- 订阅组（幂等）----
    groups = rc.get("v1/apps/#{app.id}/subscriptionGroups?limit=50").body["data"] || []
    group = groups.find { |g| g.dig("attributes", "referenceName") == group_ref }
    unless group
      group = rc.post("v1/subscriptionGroups", {
        data: {
          type: "subscriptionGroups",
          attributes: { referenceName: group_ref },
          relationships: { app: { data: { type: "apps", id: app.id } } }
        }
      }).body["data"]
      UI.success("订阅组已创建: #{group['id']}")
    end
    gid = group["id"]

    # ---- 订阅组本地化（幂等）----
    have = (rc.get("v1/subscriptionGroups/#{gid}/subscriptionGroupLocalizations?limit=50").body["data"] || [])
           .map { |l| l.dig("attributes", "locale") }
    group_locs.each do |locale, name|
      next if have.include?(locale)
      rc.post("v1/subscriptionGroupLocalizations", {
        data: {
          type: "subscriptionGroupLocalizations",
          attributes: { name: name, locale: locale },
          relationships: { subscriptionGroup: { data: { type: "subscriptionGroups", id: gid } } }
        }
      })
      UI.message("组本地化 #{locale} ✓")
    end

    # ---- 全部销售地区 id（可用范围用）----
    territories = []
    path = "v1/territories?limit=200"
    loop do
      resp = rc.get(path).body
      territories += resp["data"].map { |t| t["id"] }
      nxt = resp.dig("links", "next")
      break unless nxt
      path = nxt.sub("https://api.appstoreconnect.apple.com/", "")
    end
    UI.message("销售地区共 #{territories.count} 个")

    existing_subs = (rc.get("v1/subscriptionGroups/#{gid}/subscriptions?limit=50").body["data"] || [])

    subs_spec.each do |spec|
      sub = existing_subs.find { |s| s.dig("attributes", "productId") == spec[:product_id] }
      unless sub
        sub = rc.post("v1/subscriptions", {
          data: {
            type: "subscriptions",
            attributes: {
              name: spec[:ref_name],
              productId: spec[:product_id],
              subscriptionPeriod: spec[:period],
              familySharable: false,
              groupLevel: 1,
              reviewNote: "订阅解锁路线规划与导航功能（路线 tab）。基础自动运动记录免费。"
            },
            relationships: { group: { data: { type: "subscriptionGroups", id: gid } } }
          }
        }).body["data"]
        UI.success("订阅已创建: #{spec[:product_id]} → #{sub['id']}")
      end
      sid = sub["id"]

      # 本地化（幂等）
      have_locs = (rc.get("v1/subscriptions/#{sid}/subscriptionLocalizations?limit=50").body["data"] || [])
                  .map { |l| l.dig("attributes", "locale") }
      spec[:locs].each do |locale, (name, desc)|
        next if have_locs.include?(locale)
        rc.post("v1/subscriptionLocalizations", {
          data: {
            type: "subscriptionLocalizations",
            attributes: { name: name, description: desc, locale: locale },
            relationships: { subscription: { data: { type: "subscriptions", id: sid } } }
          }
        })
        UI.message("  #{spec[:ref_name]} 本地化 #{locale} ✓")
      end

      # 定价：找 CNY 锚点价位 → 均衡到全部地区（幂等：已有价格则跳过）
      existing_prices = rc.get("v1/subscriptions/#{sid}/prices?limit=1").body["data"] || []
      if existing_prices.any?
        UI.message("  #{spec[:ref_name]} 已有定价，跳过")
      else
        pts = rc.get("v1/subscriptions/#{sid}/pricePoints?filter[territory]=CHN&limit=8000").body["data"] || []
        anchor = pts.find { |p| p.dig("attributes", "customerPrice").to_f == spec[:price_cny] }
        UI.user_error!("找不到 CNY #{spec[:price_cny]} 的价位点") unless anchor
        UI.message("  CNY 锚点: #{anchor.dig('attributes', 'customerPrice')} (#{anchor['id']})")

        eq_path = "v1/subscriptionPricePoints/#{anchor['id']}/equalizations?include=territory&limit=8000"
        eqs = []
        loop do
          resp = rc.get(eq_path).body
          eqs += resp["data"] || []
          nxt = resp.dig("links", "next")
          break unless nxt
          eq_path = nxt.sub("https://api.appstoreconnect.apple.com/", "")
        end
        points = [anchor] + eqs
        UI.message("  共 #{points.count} 个地区价位，逐个写入…")
        created = 0
        points.each do |pt|
          # anchor 来自不带 include=territory 的查询，territory 关系为空 —— 它就是 CHN
          terr = pt.dig("relationships", "territory", "data", "id") || (pt == anchor ? "CHN" : nil)
          next unless terr
          begin
            # 注意：不传 territory 关系 —— 价位点 id 本身已编码了地区，
            # 多传 territory 会被 API 以 "error processing the pricing information" 拒绝。
            rc.post("v1/subscriptionPrices", {
              data: {
                type: "subscriptionPrices",
                relationships: {
                  subscription: { data: { type: "subscriptions", id: sid } },
                  subscriptionPricePoint: { data: { type: "subscriptionPricePoints", id: pt["id"] } }
                }
              }
            })
            created += 1
          rescue => e
            UI.important("  价位写入失败 #{terr}: #{e.message.to_s[0..120]}")
          end
        end
        UI.success("  #{spec[:ref_name]} 定价完成（#{created}/#{points.count}）")
      end

      # 可用地区：全部 + 新地区自动上架（幂等：查不到可用性才建）
      begin
        avail = rc.get("v1/subscriptions/#{sid}/subscriptionAvailability").body["data"]
      rescue
        avail = nil
      end
      unless avail
        rc.post("v1/subscriptionAvailabilities", {
          data: {
            type: "subscriptionAvailabilities",
            attributes: { availableInNewTerritories: true },
            relationships: {
              subscription: { data: { type: "subscriptions", id: sid } },
              availableTerritories: { data: territories.map { |t| { type: "territories", id: t } } }
            }
          }
        })
        UI.success("  #{spec[:ref_name]} 已设为全部地区可用")
      end
    end
    UI.success("订阅创建流程完成")
  end

  # CI build: manual signing (use on GitHub Actions where automatic signing is flaky).
  # Differs from build_and_upload: setup_ci + a temp keychain + force-refreshed profile
  # + manual code-signing settings written into the project before gym.
  desc "CI: archive + upload to ASC (runs on a macOS runner with full Xcode)"
  lane :ci_build_and_upload do
    setup_ci
    api_key = asc_api_key
    keychain = File.expand_path("~/Library/Keychains/fastlane_tmp_keychain-db")
    cert(
      api_key:           api_key,
      development:       false,
      keychain_path:     keychain,
      keychain_password: "",
      output_path:       "./fastlane/certs"
    )
    sigh(
      api_key:        api_key,
      app_identifier: APP_IDENTIFIER,
      force:          true,
      output_path:    "./fastlane/profiles"
    )
    profile_name = lane_context[SharedValues::SIGH_NAME]
    update_code_signing_settings(
      path:                  PROJECT,
      use_automatic_signing: false,
      code_sign_identity:    "Apple Distribution",
      profile_name:          profile_name,
      bundle_identifier:     APP_IDENTIFIER
    )
    gym(
      scheme:           SCHEME,
      project:          PROJECT,
      export_method:    "app-store",
      output_directory: "./build",
      output_name:      "#{SCHEME}.ipa",
      clean:            true,
      export_options:   {
        method:               "app-store",
        signingStyle:         "manual",
        provisioningProfiles: { APP_IDENTIFIER => profile_name }
      }
    )
    pilot(
      api_key:                           api_key,
      ipa:                               "./build/#{SCHEME}.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission:                   true,
      distribute_external:               false
    )
  end

  # Full auto: build → WAIT for ASC processing → submit for review. One trigger ships it.
  # Reads SUBMIT_VERSION / SUBMIT_BUILD (set them as workflow inputs / env).
  desc "CI: build + upload (wait for processing) + submit for review — full auto"
  lane :ci_release_and_submit do
    setup_ci
    api_key = asc_api_key
    keychain = File.expand_path("~/Library/Keychains/fastlane_tmp_keychain-db")
    cert(
      api_key:           api_key,
      development:       false,
      keychain_path:     keychain,
      keychain_password: "",
      output_path:       "./fastlane/certs"
    )
    sigh(
      api_key:        api_key,
      app_identifier: APP_IDENTIFIER,
      force:          true,
      output_path:    "./fastlane/profiles"
    )
    profile_name = lane_context[SharedValues::SIGH_NAME]
    update_code_signing_settings(
      path:                  PROJECT,
      use_automatic_signing: false,
      code_sign_identity:    "Apple Distribution",
      profile_name:          profile_name,
      bundle_identifier:     APP_IDENTIFIER
    )
    gym(
      scheme:           SCHEME,
      project:          PROJECT,
      export_method:    "app-store",
      output_directory: "./build",
      output_name:      "#{SCHEME}.ipa",
      clean:            true,
      export_options:   {
        method:               "app-store",
        signingStyle:         "manual",
        provisioningProfiles: { APP_IDENTIFIER => profile_name }
      }
    )
    # MUST wait for processing — otherwise the submit below can't find a usable build.
    pilot(
      api_key:                           api_key,
      ipa:                               "./build/#{SCHEME}.ipa",
      skip_waiting_for_build_processing: false,
      skip_submission:                   true,
      distribute_external:               false
    )
    submit_version
  end

  # Attach build + metadata to a version and SUBMIT for review.
  # skip_binary_upload: true → reuse the already-uploaded build (no rebuild).
  # Reads SUBMIT_VERSION / SUBMIT_BUILD. automatic_release: true → auto-release on approval
  # (set to false if you want to release manually).
  desc "Attach build + metadata to a version and submit for App Store review"
  lane :submit_version do
    deliver(
      api_key:                              asc_api_key,
      app_identifier:                       APP_IDENTIFIER,
      app_version:                          ENV.fetch("SUBMIT_VERSION"),
      build_number:                         ENV.fetch("SUBMIT_BUILD"),
      metadata_path:                        "./fastlane/metadata",
      skip_screenshots:                     true,
      skip_binary_upload:                   true,
      skip_metadata:                        false,
      skip_app_version_update:              false,
      force:                                true,
      submit_for_review:                    true,
      automatic_release:                    true,
      precheck_include_in_app_purchases:    false,
      run_precheck_before_submit:           false,
      ignore_language_directory_validation: true,
      submission_information: {
        add_id_info_uses_idfa:              false,
        export_compliance_uses_encryption:  false
      }
    )
  end

  # Fix for deliver error "A review submission is already in progress": Apple allows only
  # ONE in-progress review submission per platform. Cancel the stuck one, wait until it's
  # gone, then submit. (Safe: cancel can't harm a live version; it only withdraws an
  # un-approved submission.) Build must already be uploaded + processed.
  desc "Cancel the in-progress review submission, then submit for review"
  lane :cancel_and_submit do
    api_key = asc_api_key
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from(hash: api_key)
    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    platform = Spaceship::ConnectAPI::Platform::IOS

    existing = app.get_in_progress_review_submission(platform: platform)
    if existing
      UI.important("Canceling in-progress review submission #{existing.id}…")
      existing.cancel_submission
      cleared = false
      24.times do
        sleep(5)
        existing = app.get_in_progress_review_submission(platform: platform)
        if existing.nil?
          cleared = true
          break
        end
        UI.message("…still canceling")
      end
      UI.user_error!("Still in progress after cancel — retry later or clear it in ASC web") unless cleared
      UI.success("Old review submission cleared")
    else
      UI.message("No in-progress review submission — submitting directly")
    end

    submit_version
  end

  # All text metadata (name/subtitle/description/keywords/promo/URLs), all languages.
  # Edits the currently-editable version (skip_app_version_update: true). No build,
  # no screenshots, no submission. export LANG/LC_ALL=en_US.UTF-8 for non-ASCII text.
  desc "Upload all text metadata for all languages (no build, no screenshots, no submit)"
  lane :upload_all_metadata do
    deliver(
      api_key:                           asc_api_key,
      app_identifier:                    APP_IDENTIFIER,
      metadata_path:                     "./fastlane/metadata",
      app_rating_config_path:            "./fastlane/metadata/app_store_rating_config.json",
      skip_screenshots:                  true,
      skip_binary_upload:                true,
      skip_metadata:                     false,
      skip_app_version_update:           true,
      force:                             true,
      submit_for_review:                 false,
      automatic_release:                 false,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit:        false
    )
  end

  # Upload only "What's New" (release_notes.txt per locale) to a specific version.
  # release_notes is version-scoped, so target the version explicitly and let deliver
  # create/select its page (skip_app_version_update: false). No build, no submission.
  # NOTE: export LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 first if notes contain non-ASCII.
  desc "Upload What's-New (release notes) for all languages to a specific version"
  lane :upload_release_notes do
    deliver(
      api_key:                           asc_api_key,
      app_identifier:                    APP_IDENTIFIER,
      app_version:                       ENV["ASC_APP_VERSION"] || "1.0.0",
      metadata_path:                     "./fastlane/metadata",
      skip_screenshots:                  true,
      skip_binary_upload:                true,
      skip_metadata:                     false,
      skip_app_version_update:           false,
      force:                             true,
      submit_for_review:                 false,
      automatic_release:                 false,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit:        false
    )
  end

  # Screenshots ONLY. Run this ONLY when explicitly refreshing screenshots (major/visual
  # releases) — routine updates must NOT touch screenshots.
  desc "Upload screenshots only (no metadata, no build)"
  lane :upload_screenshots do
    deliver(
      api_key:               asc_api_key,
      app_identifier:        APP_IDENTIFIER,
      screenshots_path:      "./fastlane/screenshots",
      skip_metadata:         true,
      skip_binary_upload:    true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      force:                 true,
      submit_for_review:     false
    )
  end

  desc "Upload metadata + screenshots (no build, no review submission)"
  lane :upload_all do
    deliver(
      api_key:                    asc_api_key,
      app_identifier:             APP_IDENTIFIER,
      metadata_path:              "./fastlane/metadata",
      screenshots_path:           "./fastlane/screenshots",
      skip_binary_upload:         true,
      overwrite_screenshots:      true,
      force:                      true,
      submit_for_review:          false,
      automatic_release:          false,
      run_precheck_before_submit: false
    )
  end
end
